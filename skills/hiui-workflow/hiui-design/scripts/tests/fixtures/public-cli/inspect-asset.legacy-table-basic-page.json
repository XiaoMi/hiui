{
  "schemaVersion": "hiui-asset-inspection.v1",
  "assetType": "page-component",
  "assetId": "legacy-table-basic-page.v1",
  "componentId": "legacy-table-basic-page.v1",
  "pageTypeId": "table-basic",
  "baseMoldId": "table-basic.managed-mold.v1",
  "mode": "legacy-host-compatible",
  "supportedModes": [
    "legacy-host-compatible"
  ],
  "designSummary": {
    "purpose": "把 managed mold 的标准结构固化为当前接入模式下的页面级组件实现",
    "structureSource": "table-basic.managed-mold.v1",
    "editableAreas": [
      "pageTitle",
      "headerExtra",
      "queryFields",
      "tableColumns",
      "rowActions",
      "cellEditRules",
      "mockData",
      "apiBinding"
    ],
    "lockedAreas": [
      "shell",
      "header",
      "white-body",
      "query-filter",
      "table",
      "pagination",
      "main-scroll"
    ],
    "controlledExtensions": [
      "topNotice",
      "toolbarSupplement"
    ],
    "risks": [
      "planned / candidate / expired / blocked component 不得作为业务页起点",
      "页面实例仍必须通过 slot、extension、business mapping、route owner 与 runtime render 校验",
      "组件不得重复维护 lockedRegions / editableSlots；结构事实必须继承 baseMoldId"
    ]
  },
  "machineRules": {
    "implementationKind": "page-level-component",
    "supportedModes": [
      "legacy-host-compatible"
    ],
    "status": "planned",
    "certificationStatus": "missing",
    "fallbackPolicy": "fail-closed-when-selected",
    "adapterIds": [
      "layout-search-table-adapter"
    ],
    "supportedExtensionLevels": [
      0,
      1
    ],
    "allowedExtensions": [
      {
        "slotId": "topNotice",
        "region": "white-body.before-query-filter",
        "contentType": [
          "notice",
          "alert",
          "help-link"
        ],
        "maxComplexity": "simple",
        "forbidden": [
          "nested-table",
          "new-scroll-owner",
          "new-white-body",
          "pagination-owner-change"
        ]
      },
      {
        "slotId": "toolbarSupplement",
        "region": "table.toolbar.after-actions",
        "contentType": [
          "text",
          "badge",
          "secondary-action"
        ],
        "maxComplexity": "simple",
        "forbidden": [
          "new-toolbar-owner",
          "new-scroll-owner",
          "table-carrier-change"
        ]
      }
    ],
    "inheritedLockedRegions": [
      "shell",
      "header",
      "white-body",
      "query-filter",
      "table",
      "pagination",
      "main-scroll"
    ],
    "inheritedEditableSlots": [
      "pageTitle",
      "headerExtra",
      "queryFields",
      "tableColumns",
      "rowActions",
      "cellEditRules",
      "mockData",
      "apiBinding"
    ],
    "requiredValidation": [
      "component-certification",
      "page-instance-validation",
      "preflight"
    ]
  }
}
