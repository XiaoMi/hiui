{
  "schemaVersion": 1,
  "bundleName": "hiui-workflow",
  "defaultPolicy": {
    "onMissing": "install",
    "onSameVersion": "skip",
    "onOlderVersion": "upgrade",
    "onNewerVersion": "keep",
    "onUnknownVersion": "backup-and-upgrade",
    "onLocalModifications": "backup-and-upgrade",
    "allowDowngrade": false,
    "createBackups": true,
    "atomicReplace": true
  },
  "supportedFlags": [
    "--dry-run",
    "--host",
    "--reinstall",
    "--force-sync",
    "--allow-downgrade",
    "--target"
  ]
}
