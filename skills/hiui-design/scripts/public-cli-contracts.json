          }
        ]
      },
      {
        "id": "typical-page-start-page",
        "script": "scripts/typical-page-start-page.mjs",
        "status": "shipped",
        "jsonContract": "shipped",
        "command": [
          "--target",
          "<skillRoot>",
          "--page-type",
          "table-basic",
          "--mode",
          "rules-only",
          "--page",
          "src/pages/orders/index.tsx",
