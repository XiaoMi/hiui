        "jsonContract": "shipped",
        "command": [
          "--target",
          "<skillRoot>",
          "--page",
          "src/pages/orders/index.tsx",
          "--report-mode",
          "rules-only",
          "--prompt",
          "preview-ready contract fixture",
          "--contract-fixture",
          "quality-pass"
