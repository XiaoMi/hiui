        "fixture": "scripts/tests/fixtures/public-cli/preview-ready.quality-pass.json",
        "requiredTopLevelFields": [
          "ok",
          "previewReady",
          "checks",
          "normalizedPagePath",
          "pageTypeId",
          "qualityChecks",
          "qualityVerified",
          "requiredRegions",
