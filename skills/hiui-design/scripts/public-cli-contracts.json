          {
            "path": ["contract", "workflow"],
            "fields": ["status", "deliveryStatus", "preflightStatus", "sourceGateStatus", "doctorStatus", "runtimeSmokeStatus", "sourceSnapshotHash"]
          }
        ]
      }
    ],
    "human-cli": [
      "setup-for-designers",
      "apply-in-current-project",
