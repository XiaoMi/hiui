        "script": "scripts/typical-page-runtime-smoke.mjs",
        "status": "shipped",
        "jsonContract": "shipped",
        "command": [
          "--url",
          "http://runtime-smoke.fixture.invalid/visual-missing",
          "--profile",
          "visual",
          "--viewport",
          "390x844",
          "--contract-fixture",
          "visual-missing",
          "--json"
