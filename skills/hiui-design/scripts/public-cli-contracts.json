{
  "version": 1,
  "description": "Machine-readable contract tiers for hiui-design scripts. Shipped machine-public entries must keep stable JSON fixtures.",
  "tiers": {
    "machine-public": [
      {
        "id": "plan-page-task",
        "script": "scripts/plan-page-task.mjs",
        "status": "shipped",
        "jsonContract": "shipped",
        "command": [
          "--change",
          "新增一个数据看板页面",
          "--page-type",
          "table-stat",
          "--mode",
          "rules-only",
          "--target",
          "<skillRoot>",
          "--json"
        ],
        "fixture": "scripts/tests/fixtures/public-cli/plan-page-task.table-stat.json",
        "requiredTopLevelFields": [
          "version",
          "contractVersion",
          "taskLevel",
          "mode",
          "pageType",
          "isNonTypical",
          "layoutOverlayRequired",
          "requiredDocs",
          "requiredCommands",
          "conditionalCommands",
          "contractFieldsNeeded",
          "kickoffSkeleton",
          "runtimeSmokePlan",
          "usagePolicy",
          "factsSource",
          "canStartImplementation",
          "blockingReasons",
          "decisionTracePath"
        ],
        "requiredNestedFields": [
          {
            "path": ["taskLevel"],
            "fields": ["id", "source"]
          },
          {
            "path": ["mode"],
            "fields": ["id", "source"]
          },
          {
            "path": ["pageType"],
            "fields": ["id", "label", "source"]
          },
          {
            "path": ["runtimeSmokePlan"],
            "fields": ["required", "command"]
          },
          {
            "path": ["usagePolicy"],
            "fields": ["mode", "source", "requireNetworkAuthorization"]
          }
        ]
      },
      {
