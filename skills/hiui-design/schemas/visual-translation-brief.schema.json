{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hiui-design/visual-translation-brief.schema.json",
  "type": "object",
  "required": ["schemaVersion", "status", "statusReasons", "source"],
  "properties": {
    "schemaVersion": {"const": "visual-translation-brief.v1"},
    "status": {"enum": ["ready", "blocked", "invalid"]},
    "statusReasons": {"type": "array", "items": {"type": "string"}},
    "source": {"type": "object"},
    "observation": {"type": "object"},
    "extractedFacts": {"type": "object"},
    "normalization": {
      "type": "object",
      "properties": {
        "preserve": {"type": "array", "items": {"type": "string"}},
        "discard": {"type": "array", "items": {"type": "string"}},
        "hiuiRecommendations": {"type": "array", "maxItems": 3, "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "pageTypeCandidates": {"type": "array", "maxItems": 3, "items": {"type": "object"}},
    "prePlanBlockingFacts": {"type": "array", "items": {"type": "object"}},
    "blockingIssues": {"type": "array", "items": {"type": "object"}},
    "blockingReasons": {"type": "array", "items": {"type": "string"}},
    "planningHints": {
      "type": "object",
      "properties": {
        "intentSummary": {"type": "string"},
        "constraints": {"type": "array", "maxItems": 3, "items": {"type": "string"}},
        "evidenceRefs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
