{
  "schemaVersion": "adapter-registry.v1",
  "adapters": [
    {
      "adapterId": "legacy-runtime-adapter",
      "kind": "legacy-runtime-adapter",
      "label": "Legacy runtime bridge for certified page components",
      "supportedModes": [
        "legacy-host-compatible"
      ],
      "responsibility": "runtime-bridge-only",
      "allowedResponsibilities": [
        "query-field-schema-binding",
        "table-column-schema-binding",
        "pagination-state-binding",
        "request-schema-binding",
        "response-schema-binding",
        "message-bridge",
        "i18n-bridge",
        "permission-bridge",
        "modal-container-binding",
        "scroll-owner-proof",
        "style-scope-proof"
      ],
      "forbiddenResponsibilities": [
        "translate-hiui-components-to-legacy-components",
        "replace-query-filter-with-legacy-form",
        "replace-managed-table-with-legacy-table",
        "reimplement-pagination-region",
        "wrap-typical-page-as-business-page-component",
        "shell",
        "page-header-geometry",
        "white-body-owner",
        "outer-padding-owner",
        "main-scroll-owner"
      ],
      "mustNot": [
        "translateHiuiComponentsToLegacyComponents",
        "replaceQueryFilterWithLegacyForm",
        "replaceManagedTableWithLegacyTable",
        "reimplementPaginationRegion",
        "wrapTypicalPageAsBusinessPageComponent"
      ],
      "allowedLocalBypassContainment": [
        "section-body",
        "panel-body",
        "field-control",
        "cell-body"
      ],
      "primitiveUsagePolicy": {
        "hiui5": "leaf-control-or-managed-section-only",
        "@hi-ui/icons": "leaf-icon-only"
      }
    },
    {
      "adapterId": "layout-search-table-adapter",
      "label": "Single white-body list workspace",
      "supportedModes": [
        "legacy-host-compatible",
        "rules-only",
        "host-integration"
      ],
      "allowedResponsibilities": [
        "header-slot-binding",
        "query-field-schema-binding",
        "table-column-schema-binding",
        "pagination-state-binding",
        "legacy-hiui-runtime-bridge"
      ],
      "forbiddenResponsibilities": [
        "shell",
        "page-header-geometry",
        "white-body-owner",
        "outer-padding-owner",
        "main-scroll-owner",
        "translate-hiui-components-to-legacy-components",
        "replace-query-filter-with-legacy-form",
        "replace-managed-table-with-legacy-table",
        "reimplement-pagination-region",
        "wrap-typical-page-as-business-page-component"
      ],
      "allowedLocalBypassContainment": [
        "section-body",
        "panel-body",
        "field-control",
        "cell-body"
      ],
      "primitiveUsagePolicy": {
        "hiui5": "leaf-control-or-managed-section-only",
        "@hi-ui/icons": "leaf-icon-only"
      },
      "headerSlotBinding": {
        "sourceRequirement": "must inherit from a shipped example, managed shell, shared host adapter, or upstream host carrier",
        "editableSlots": [
          "pageTitle",
          "headerExtra",
          "onBack",
          "statusText",
          "primaryAction"
        ],
        "forbiddenPageResponsibilities": [
          "local-createPortal-page-header",
          "local-header-portal-component",
          "page-header-geometry",
          "page-header-padding",
          "page-header-align-items",
          "hi-v5-page-header-skeleton"
        ]
      },
      "kind": "legacy-runtime-adapter",
      "responsibility": "runtime-bridge-only",
      "mustNot": [
        "translateHiuiComponentsToLegacyComponents",
        "replaceQueryFilterWithLegacyForm",
        "replaceManagedTableWithLegacyTable",
        "reimplementPaginationRegion",
        "wrapTypicalPageAsBusinessPageComponent"
      ]
    },
    {
      "adapterId": "layout-search-stat-table-adapter",
      "label": "Single white-body stat/search/table workspace",
