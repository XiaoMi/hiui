{
  "id": "tree-split-core",
  "version": 1,
  "pageTypeId": "tree-split",
  "label": "Tree split archetype",
  "shell": "TreeSplitPageFrame",
  "examplePath": "examples/host-integration/src/pages/inventory-split.tsx",
  "requiredStartFromExample": true,
  "structuralContract": {
    "singleExample": true,
