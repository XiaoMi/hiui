{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": [
        "^build"
      ]
    },
    "build:types": {
      "dependsOn": [
        "^build:types"
      ]
    },
    "clean": {
      "cache": false
    },
    "auto-generate": {
      "cache": false
    },
    "generate-docs": {
      "cache": false
    }
  }
}
