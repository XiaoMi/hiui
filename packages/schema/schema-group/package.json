{
  "name": "@hi-ui/schema-group",
  "version": "4.0.0-experimental.4",
  "description": "A sub-package for @hi-ui/schema.",
  "keywords": [],
  "author": "HiUI <mi-hiui@xiaomi.com>",
  "homepage": "https://github.com/XiaoMi/hiui/tree/master/packages/schema/schema-group#readme",
  "license": "MIT",
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "lib",
    "form.js",
    "form.d.ts",
    "table.js",
    "table.d.ts",
    "descriptions.js",
    "descriptions.d.ts",
    "edit-table.js",
    "edit-table.d.ts",
    "bundle.js",
    "bundle.d.ts"
  ],
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "default": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./bundle": {
      "default": "./bundle.js",
      "types": "./bundle.d.ts"
    },
    "./form": {
      "default": "./form.js",
      "types": "./form.d.ts"
    },
    "./table": {
      "default": "./table.js",
      "types": "./table.d.ts"
    },
    "./descriptions": {
      "default": "./descriptions.js",
      "types": "./descriptions.d.ts"
    },
    "./edit-table": {
      "default": "./edit-table.js",
      "types": "./edit-table.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XiaoMi/hiui.git"
  },
  "scripts": {
    "test": "jest",
    "clean": "rimraf lib form.* table.* descriptions.* edit-table.* bundle.*",
    "prebuild": "yarn clean",
    "build:esm": "hi-build ./src/index.ts --format esm -d ./lib",
    "build:bundle:esm": "hi-build ./src/group-context/bundle.tsx --format esm -d ./lib",
    "build:types": "tsc --emitDeclarationOnly --declaration --declarationDir ./lib",
    "build-alias": "node scripts/build-alias.mjs",
    "build": "yarn build:bundle:esm && yarn build:esm && yarn build:types && yarn build-alias"
  },
  "bugs": {
    "url": "https://github.com/XiaoMi/hiui/issues"
  },
  "dependencies": {
    "@hi-ui/card": ">=5.0.0-experimental.0",
    "@hi-ui/classname": ">=5.0.0-experimental.0",
    "@hi-ui/group": ">=4.0.0-experimental.2",
    "@hi-ui/schema-action-trigger": ">=4.0.0-experimental.4",
    "@hi-ui/schema-auto-grid": ">=4.0.0-experimental.1",
    "@hi-ui/schema-descriptions": ">=4.0.0-experimental.2",
    "@hi-ui/schema-editable-table": ">=4.0.0-experimental.5",
    "@hi-ui/schema-form": ">=4.0.0-experimental.2",
    "@hi-ui/schema-table": ">=4.0.0-experimental.1",
    "@hi-ui/schema-utils": ">=4.0.0-experimental.1",
    "@hi-ui/tabs": ">=5.0.0-experimental.0",
    "ahooks": "^3.9.6",
    "lodash-es": "^4.17.23"
  },
  "peerDependencies": {
    "@hi-ui/schema-core": ">=4.0.0-experimental.7",
    "@hi-ui/utility-types": ">=4.0.0-experimental.1",
    "@hi-ui/use-ref-state": ">=4.0.0-experimental.1",
    "react": ">=16.8.6"
  },
  "devDependencies": {
    "@hi-ui/schema-core": ">=4.0.0-experimental.7",
    "@hi-ui/utility-types": ">=4.0.0-experimental.1",
    "@hi-ui/use-ref-state": ">=4.0.0-experimental.1",
    "react": "^17.0.2"
  },
  "volta": {
    "node": "14.21.3"
  }
}
